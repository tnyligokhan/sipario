{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_FLOW_V3_ENABLED": "true",
    "CLAUDE_FLOW_HOOKS_ENABLED": "true"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npx @claude-flow*)",
      "Bash(npx claude-flow*)",
      "Bash(node .claude/*)",
      "mcp__claude-flow__*",
      "Bash(php -v)",
      "Bash(php -m)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Get-Item *)",
      "PowerShell(Get-Location)",
      "PowerShell(Get-Command *)",
      "PowerShell(Test-Path *)",
      "PowerShell(Select-String *)",
      "PowerShell(git status *)",
      "PowerShell(git log *)",
      "PowerShell(git diff *)",
      "PowerShell(git branch *)",
      "PowerShell(git rev-list *)",
      "PowerShell(docker ps *)",
      "PowerShell(php -v)",
      "PowerShell(php -m *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/hook-handler.cjs\"; if [ -f \"$f\" ]; then node \"$f\" pre-bash; fi",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/hook-handler.cjs\"; if [ -f \"$f\" ]; then node \"$f\" pre-edit; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/hook-handler.cjs\"; if [ -f \"$f\" ]; then node \"$f\" post-edit; fi",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/hook-handler.cjs\"; if [ -f \"$f\" ]; then node \"$f\" post-bash; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/hook-handler.cjs\"; if [ -f \"$f\" ]; then node \"$f\" route; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/hook-handler.cjs\"; if [ -f \"$f\" ]; then node \"$f\" session-restore; fi",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/auto-memory-hook.mjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/auto-memory-hook.mjs\"; if [ -f \"$f\" ]; then node \"$f\" import; fi",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/scripts/shift-sync-check.ps1\"; [ -f \"$f\" ] && powershell -NoProfile -ExecutionPolicy Bypass -File \"$f\" || true",
            "timeout": 60,
            "statusMessage": "Vardiya senkron kontrolu..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/hook-handler.cjs\"; if [ -f \"$f\" ]; then node \"$f\" session-end; fi",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/auto-memory-hook.mjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/auto-memory-hook.mjs\"; if [ -f \"$f\" ]; then node \"$f\" sync; fi",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/scripts/quality-gate-commit.ps1\"; [ -f \"$f\" ] && powershell -NoProfile -ExecutionPolicy Bypass -File \"$f\" || true",
            "timeout": 600,
            "statusMessage": "Kalite kapisi + otomatik commit calisiyor..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/hook-handler.cjs\"; if [ -f \"$f\" ]; then node \"$f\" compact-manual; fi",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/hook-handler.cjs\"; if [ -f \"$f\" ]; then node \"$f\" session-end; fi",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/hook-handler.cjs\"; if [ -f \"$f\" ]; then node \"$f\" compact-auto; fi",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/hook-handler.cjs\"; if [ -f \"$f\" ]; then node \"$f\" session-end; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/hook-handler.cjs\"; if [ -f \"$f\" ]; then node \"$f\" status; fi",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/hook-handler.cjs\"; if [ -f \"$f\" ]; then node \"$f\" post-task; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\"; [ -f \"$f\" ] || f=\"$HOME/.claude/helpers/hook-handler.cjs\"; if [ -f \"$f\" ]; then node \"$f\" notify; fi",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node -e \"const fs=require('fs'),p=require('path');const d=process.env.CLAUDE_PROJECT_DIR||'.';const f=p.join(d,'.claude/helpers/statusline.cjs');const h=p.join(process.env.USERPROFILE||process.env.HOME||'.', '.claude/helpers/statusline.cjs');require(fs.existsSync(f)?f:h);\""
  },
  "enabledPlugins": {
    "ruflo-adr@ruflo": true,
    "ruflo-cost-tracker@ruflo": true,
    "ruflo-security-audit@ruflo": true,
    "ruflo-testgen@ruflo": true
  },
  "claudeFlow": {
    "version": "3.0.0",
    "enabled": true,
    "platform": {
      "os": "windows",
      "arch": "x64",
      "shell": "powershell"
    },
    "modelPreferences": {
      "default": "claude-opus-4-8",
      "routing": "claude-haiku-4-5-20251001"
    },
    "agentTeams": {
      "enabled": true,
      "teammateMode": "auto",
      "taskListEnabled": true,
      "mailboxEnabled": true,
      "coordination": {
        "autoAssignOnIdle": true,
        "trainPatternsOnComplete": true,
        "notifyLeadOnComplete": true,
        "sharedMemoryNamespace": "agent-teams"
      },
      "hooks": {
        "teammateIdle": {
          "enabled": true,
          "autoAssign": true,
          "checkTaskList": true
        },
        "taskCompleted": {
          "enabled": true,
          "trainPatterns": true,
          "notifyLead": true
        }
      }
    },
    "swarm": {
      "topology": "hierarchical-mesh",
      "maxAgents": 5
    },
    "memory": {
      "backend": "hybrid",
      "enableHNSW": true,
      "learningBridge": {
        "enabled": true
      },
      "memoryGraph": {
        "enabled": true
      },
      "agentScopes": {
        "enabled": true
      }
    },
    "neural": {
      "enabled": true
    },
    "daemon": {
      "autoStart": false,
      "workers": [
        "map",
        "audit",
        "optimize"
      ],
      "schedules": {
        "audit": {
          "interval": "4h",
          "priority": "critical"
        },
        "optimize": {
          "interval": "2h",
          "priority": "high"
        }
      }
    },
    "learning": {
      "enabled": true,
      "autoTrain": true,
      "patterns": [
        "coordination",
        "optimization",
        "prediction"
      ],
      "retention": {
        "shortTerm": "24h",
        "longTerm": "30d"
      }
    },
    "adr": {
      "autoGenerate": true,
      "directory": "/docs/adr",
      "template": "madr"
    },
    "ddd": {
      "trackDomains": true,
      "validateBoundedContexts": true,
      "directory": "/docs/ddd"
    },
    "security": {
      "autoScan": true,
      "scanOnEdit": true,
      "cveCheck": true,
      "threatModel": true
    }
  },
  "worktree": {
    "bgIsolation": "none"
  }
}
