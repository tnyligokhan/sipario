<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <!-- RLS SQLite'ta yoktur; testler GERCEK Postgres'e kosar. Baglanti sipario_app roluyle
             (superuser/BYPASSRLS DEGIL) kurulur ki izolasyon gercekten sinansin. Migration ise
             pgsql_owner baglantisiyla kosulur (bkz. ApiTestCase; migrate:fresh owner rolunde).
             force yok: CI kendi env degerleriyle bunlari gecersiz kilar. -->
        <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_PORT" value="55432"/>
        <env name="DB_DATABASE" value="sipario_test"/>
        <env name="DB_USERNAME" value="sipario_app"/>
        <env name="DB_PASSWORD" value="sipario_app_dev"/>
        <env name="DB_OWNER_USERNAME" value="sipario_owner"/>
        <env name="DB_OWNER_PASSWORD" value="sipario_owner_dev"/>
        <!-- Panel rolu (Faz 5c): BYPASSRLS cross-tenant okur, is verisine YAZAMAZ (grant matrisi). -->
        <env name="DB_PANEL_USERNAME" value="sipario_panel"/>
        <env name="DB_PANEL_PASSWORD" value="sipario_panel_dev"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
