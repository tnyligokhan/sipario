APP_NAME=Sipario
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Veritabanı ---------------------------------------------------------------
# RUNTIME bağlantısı app rolüyle koşar: superuser DEĞİL, BYPASSRLS DEĞİL → RLS uygulanır.
# Host portu 55432: docker-compose Postgres'i 55432'de yayınlar (geliştirici makinelerindeki
# yerli PostgreSQL 5432'yi tutuyor; standart port sessizce yanlış sunucuya bağlanma riski taşır).
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=55432
DB_DATABASE=sipario
DB_USERNAME=sipario_app
DB_PASSWORD=sipario_app_dev

# Migration/deploy için ayrı SAHİP rolü (aynı DB). config/database.php'deki `pgsql_owner`
# bağlantısı bunu kullanır. Tablo/policy'leri owner oluşturur; app rolü yalnız DML yapar.
DB_OWNER_USERNAME=sipario_owner
DB_OWNER_PASSWORD=sipario_owner_dev

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
